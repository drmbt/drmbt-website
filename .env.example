# Cloudflare R2 credentials — required only for `npm run media:push`.
# Copy to .env (gitignored) and fill in.
#
# Cloudflare dashboard → R2:
#   1. Create a bucket (suggested name below).
#   2. Bucket → Settings → Public access: connect custom domain
#      media.drmbt.com (or enable the r2.dev URL to start) — whichever you
#      choose, put that URL in media.config.json "baseUrl".
#   3. R2 → Manage API Tokens → Create token with Object Read & Write
#      scoped to the bucket. Account ID is in the R2 overview sidebar.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=drmbt-media
